# Local Raspberry Pi dashboard secrets.
# Copy to .env on the Pi and fill with local camera and cloud credentials.
TAPO_CAMERA_USERNAME=replace_me
TAPO_CAMERA_PASSWORD=replace_me
WYZE_RTSP_USERNAME=replace_me
WYZE_RTSP_PASSWORD=replace_me
CHORTAU_CAMERA_USERNAME=replace_me
CHORTAU_CAMERA_PASSWORD=replace_me

# Tuya IoT Cloud credentials. Region examples: us, eu, cn, in.
TUYA_ACCESS_ID=replace_me
TUYA_ACCESS_SECRET=replace_me
TUYA_API_REGION=us
# Optional but useful for TinyTuya Cloud projects; use any linked Tuya device ID.
TUYA_DEVICE_ID=replace_me

# Govee Bluetooth LED strips use Raspberry Pi BLE discovery; no cloud key required.
# Lepro S1 AI LED via Alexa needs an Alexa routine/bridge path before dashboard commands are available.
